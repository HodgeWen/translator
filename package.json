{
  "name": "translator-extension",
  "version": "0.4.1",
  "description": "A modern browser translation extension with OpenAI-compatible LLM support",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "release": "bun scripts/release.mjs",
    "release:verify": "bun scripts/verify-release.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "dexie": "^4.0.11",
    "franc-min": "^6.2.0",
    "zod": "^4.4.3",
    "lucide-react": "^1.14.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "@uiw/react-codemirror": "^4.25.9",
    "@uiw/codemirror-theme-material": "^4.25.9",
    "@codemirror/lang-json": "^6.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/chrome": "^0.1.42",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26",
    "tailwindcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "oxfmt": "^0.49.0"
  }
}
